{
  "name": "desktop-application-workspace",
  "private": true,
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "husky": "^9.1.7"
  },
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "dev:prepare": "bun run scripts/dev-prepare.ts",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:backend": "bun run scripts/run-binary.ts",
    "build": "bun run scripts/build.ts",
    "test": "bun run scripts/test.ts",
    "test:frontend": "bun run scripts/test.ts frontend",
    "test:go": "bun run scripts/test.ts go",
    "style-check": "bun run scripts/style.ts check",
    "style-fix": "bun run scripts/style.ts fix",
    "update:deps": "bun run scripts/update-dependencies.ts",
    "sync-app-config": "bun run scripts/sync-app-config.ts",
    "release": "bun run scripts/release.ts",
    "metadata": "bun run scripts/metadata.ts",
    "prepare": "husky"
  }
}
